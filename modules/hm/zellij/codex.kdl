layout {
  default_tab_template {
    pane size=1 borderless=true {
      plugin location="zellij:tab-bar"
    }
    children
    pane size=1 borderless=true {
      plugin location="zellij:status-bar"
    }
  }
  tab name="w0" cwd="w0" {
    pane split_direction="vertical" {
      pane command="codex"
      pane command="codex"
    }
  }
  tab name="w1" cwd="w1" {
    pane split_direction="vertical" {
      pane command="codex"
      pane command="codex"
    }
  }
  tab name="w2" cwd="w2" {
    pane split_direction="vertical" {
      pane command="codex"
      pane command="codex"
    }
  }
  tab name="w3" cwd="w3" {
    pane split_direction="vertical" {
      pane command="codex"
      pane command="codex"
    }
  }
  tab name="w4" cwd="w4" {
    pane split_direction="vertical" {
      pane command="codex"
      pane command="codex"
    }
  }
}
